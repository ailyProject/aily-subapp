{
  "name": "@aily-project/subapp-aily-chat",
  "version": "0.1.0",
  "private": true,
  "description": "React child application for Aily Chat",
  "main": "index.js",
  "bin": {
    "aily-chat": "index.js"
  },
  "scripts": {
    "start": "node index.js rpc",
    "serve": "node index.js serve",
    "build:icons": "node scripts/build-icons-css.mjs",
    "build:ui": "node scripts/build-icons-css.mjs && node scripts/build-ui.mjs",
    "install:ui": "npm install --prefix ui",
    "cli": "node index.js",
    "status": "node index.js status",
    "echo": "node index.js echo"
  },
  "dependencies": {
    "penpal": "^7.0.6",
    "ws": "^8.21.0"
  }
}
